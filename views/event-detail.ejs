<!-- ./views/event-detail.ejs -->
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title><%= event.title %></title>
</head>
<body>
<h1><%= event.title %></h1>
<p><%= event.description %></p>
<p>Ort: <%= event.location %></p>
<p>Datum: <%= event.date ? new Date(event.date).toLocaleDateString() : '' %></p>
<p>Start: <%= event.startDate ? new Date(event.startDate).toLocaleString() : '' %> Uhr</p>
<p>Ende: <%= event.endDate ? new Date(event.endDate).toLocaleString() : '' %> Uhr</p>
<p>Anmeldefrist: <%= event.registrationDeadline ? new Date(event.registrationDeadline).toLocaleString() : '' %></p>

<% if (!isRegistrationDeadlinePassed) { %>
    <form method="POST" action="/event/<%= event._id %>/register">
        <label for="firstName">Vorname:</label>
        <input type="text" id="firstName" name="firstName" required><br><br>

        <label for="lastName">Nachname:</label>
        <input type="text" id="lastName" name="lastName" required><br><br>

        <label for="email">E-Mail:</label>
        <input type="email" id="email" name="email" required><br><br>

        <button type="submit">Anmelden</button>
    </form>
<% } else { %>
    <p class="deadline-expired">Anmeldefrist abgelaufen.</p>
<% } %>
</body>
</html>